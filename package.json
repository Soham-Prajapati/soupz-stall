{
    "name": "soupz",
    "version": "0.2.0",
    "description": "Code from anywhere — AI coding IDE that bridges your phone to your laptop",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "bin": {
        "soupz": "./bin/soupz.js",
        "soupz-cockpit": "./bin/soupz.js"
    },
    "scripts": {
        "setup": "node --max-old-space-size=4096 scripts/setup.js",
        "start": "node --max-old-space-size=4096 bin/soupz.js",
        "dev": "node --max-old-space-size=4096 bin/soupz.js",
        "dev:web": "node --max-old-space-size=4096 scripts/dev-web-stack.js",
        "dev:web:pnpm": "SOUPZ_PM=pnpm node --max-old-space-size=4096 scripts/dev-web-stack.js",
        "dev:web:npm": "SOUPZ_PM=npm node --max-old-space-size=4096 scripts/dev-web-stack.js",
        "test": "vitest run",
        "postinstall": "node --max-old-space-size=4096 src/auto-import.js && (cd packages/remote-server && npm install --silent 2>/dev/null) || true"
    },
    "devDependencies": {
        "vitest": "^3.2.4"
    },
    "optionalDependencies": {
        "node-pty": "^1.0.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.98.0",
        "chalk": "^5.3.0",
        "conf": "^13.0.1",
        "dotenv": "^17.3.1",
        "express": "^4.21.0",
        "figlet": "^1.8.0",
        "gradient-string": "^3.0.0",
        "meow": "^13.0.0",
        "puppeteer-core": "^24.37.5",
        "qrcode": "^1.5.4",
        "tree-kill": "^1.2.2",
        "ws": "^8.18.0",
        "yaml": "^2.6.1"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "ai",
        "cli",
        "agent",
        "orchestrator",
        "jarvis",
        "copilot",
        "gemini",
        "personas",
        "kiro",
        "soupz"
    ],
    "author": "Your Name",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Soham-Prajapati/soupz-stall.git"
    },
    "bugs": {
        "url": "https://github.com/Soham-Prajapati/soupz-stall/issues"
    },
    "homepage": "https://soupz.vercel.app"
}
