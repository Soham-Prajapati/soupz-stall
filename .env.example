# Soupz environment template
# Copy to .env — never commit real keys.

# ─── Supabase (core relay + auth) ───────────────────────────────
SOUPZ_SUPABASE_URL=
SOUPZ_SUPABASE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SOUPZ_SUPABASE_ORDERS_TABLE=soupz_orders

# ─── AI CLI Providers (bring your own — install these CLIs) ─────
# GitHub Copilot:  gh auth login
# Google Gemini:   gemini auth login
# Claude Code:     claude auth login (or ANTHROPIC_API_KEY below)
# Kiro:            kiro auth login
# Ollama (local):  ollama serve (free, no key needed)

# ─── AI API Key Providers (alternative if you don't have CLIs) ──
ANTHROPIC_API_KEY=          # Claude models (claude-sonnet-4-6, claude-opus-4-6)
OPENAI_API_KEY=              # GPT models (gpt-4o, gpt-4o-mini)
GROQ_API_KEY=                # Groq ultra-fast inference (llama 3.3 70B, free tier)
OPENROUTER_API_KEY=          # OpenRouter — 200+ models, single key
GEMINI_API_KEY=              # Google Gemini API (alternative to CLI)

# ─── Provider Selection ─────────────────────────────────────────
# Preferred API provider when multiple are available (anthropic|openai|groq|openrouter|gemini)
SOUPZ_API_PROVIDER=

# Routing strategy: copilot | ollama | api | auto (default: auto)
SOUPZ_ROUTER=auto

# ─── Cost Optimization ──────────────────────────────────────────
# Enable language bridge (Mandarin intermediate for 25-35% token savings)
SOUPZ_LANG_BRIDGE=false
# Model tier preference: fast | balanced | powerful (default: balanced)
SOUPZ_MODEL_TIER=balanced

# ─── Local Ollama ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_ROUTER_MODEL=qwen2.5:1.5b

# ─── Server ─────────────────────────────────────────────────────
SOUPZ_REMOTE_PORT=7533
SOUPZ_WEB_AGENT=auto
