# Soupz Stall environment template
# Copy to your shell export workflow (do not commit real keys).

# Core auth (src/auth/user-auth.js)
SOUPZ_SUPABASE_URL=
SOUPZ_SUPABASE_KEY=

# Remote server order persistence (packages/remote-server/src/index.js)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SOUPZ_SUPABASE_ORDERS_TABLE=soupz_orders

# Optional web defaults
SOUPZ_WEB_AGENT=copilot
SOUPZ_REMOTE_PORT=7533
